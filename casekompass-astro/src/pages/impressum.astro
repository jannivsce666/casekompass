<Layout title="Impressum - CaseKompass" description="Impressum von CaseKompass – Alltagsbegleitung und Case Management in Herbrechtingen.">
<main class="legal-page">
    <section class="section">
      <div class="container">
        <div class="legal-content">
          <h1><i class="fa-solid fa-gavel"></i> Impressum</h1>

          <h2>Angaben gemäß § 5 DDG</h2>

          <div class="impressum-section">
            <h3>Anbieter dieser Website</h3>
            <p>
              Johannes Piperidis<br>
              CaseKompass<br>
              Alltagsbegleitung, Pflegehilfe & Case Management
            </p>
          </div>

          <div class="impressum-section">
            <h3>Anschrift</h3>
            <p>
              Albstr. 5<br>
              89542 Herbrechtingen<br>
              Deutschland
            </p>
          </div>

          <div class="impressum-section">
            <h3>Kontakt</h3>
            <p>
              Telefon: <a href="tel:+4915226560105">01522 6560105</a><br>
              E-Mail: <a href="mailto:casekompass@gmx.de">casekompass@gmx.de</a><br>
              Website: <a href="https://casekompass.de" target="_blank" rel="noopener">casekompass.de</a>
            </p>
